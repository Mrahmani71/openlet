{
  "extends": "./tsconfig.base.json",

  "compilerOptions": {
    /* -------------------------------------------------------------------------- */
    /* Runtime Target                                                              */
    /* -------------------------------------------------------------------------- */

    "target": "ES2022",
    "lib": ["ES2022"],

    /* -------------------------------------------------------------------------- */
    /* Node.js ESM                                                                 */
    /* -------------------------------------------------------------------------- */

    "module": "ESNext",
    "moduleResolution": "Bundler",

    /* -------------------------------------------------------------------------- */
    /* Environment Types                                                           */
    /* -------------------------------------------------------------------------- */

    "types": ["node"],

    /* -------------------------------------------------------------------------- */
    /* Additional Features                                                         */
    /* -------------------------------------------------------------------------- */

    "resolveJsonModule": true,

    /* -------------------------------------------------------------------------- */
    /* Debugging                                                                   */
    /* -------------------------------------------------------------------------- */

    "sourceMap": true
  }
}
